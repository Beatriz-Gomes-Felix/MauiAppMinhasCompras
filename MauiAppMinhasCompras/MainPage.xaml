<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.MainPage"
             Title="Minhas Compras">

    <Grid RowDefinitions="Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Entry x:Name="txtDescricao" Placeholder="Descrição do Produto" />

            <HorizontalStackLayout Spacing="10">
                <Entry x:Name="txtQuantidade" Placeholder="Qtd" Keyboard="Numeric" WidthRequest="80"/>
                <Entry x:Name="txtPreco" Placeholder="Preço" Keyboard="Numeric" WidthRequest="100"/>

                <Picker x:Name="pckCategoria" Title="Categoria" WidthRequest="120">
                    <Picker.Items>
                        <x:String>Alimentos</x:String>
                        <x:String>Higiene</x:String>
                        <x:String>Limpeza</x:String>
                        <x:String>Outros</x:String>
                    </Picker.Items>
                </Picker>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Data da Compra:" VerticalOptions="Center" />
                <DatePicker x:Name="dtpData" Format="dd/MM/yyyy" />
            </HorizontalStackLayout>

            <Button Text="Adicionar Produto" Clicked="OnSalvarClicked" BackgroundColor="DarkViolet" />

            <SearchBar x:Name="searchBar" 
                       Placeholder="Buscar produto..." 
                       TextChanged="OnSearchTextChanged" 
                       Margin="0,10,0,0" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" x:Name="atualizarLista" Refreshing="OnAtualizarLista">
            <CollectionView x:Name="listaProdutos" 
                            Margin="0,20,0,0"
                            SelectionMode="Single"
                            SelectionChanged="OnItemSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Deletar" 
                                               BackgroundColor="Red" 
                                               Invoked="OnDeletarClicked" 
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Margin="0,5" Padding="15">
                                <VerticalStackLayout Spacing="5">
                                    <HorizontalStackLayout Spacing="20">
                                        <Label Text="{Binding Descricao}" FontAttributes="Bold" FontSize="16" />
                                        <Label Text="{Binding Categoria}" TextColor="Gray" FontSize="12" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="20">
                                        <Label Text="{Binding Quantidade, StringFormat='Qtd: {0}'}" />

                                        <Label Text="{Binding Preco, StringFormat='{0:C2}'}" />

                                        <Label Text="{Binding DataCadastro, StringFormat='{0:dd/MM/yy}'}" FontSize="12" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>